# Dataset composition (unchanged)
composition:
  samples: 8
  cell_lines: 7
  total_cells: 29528
  species: "Homo sapiens"
  taxon_id: 9606
  platform: "Illumina NovaSeq 6000"
  chemistry: "10X Genomics Single Cell 3' v3.1"
  cell_lines_detail:
    - name: "PC9"
      mutation: "EGFR Del19"
      cells: 4492
    - name: "A549"
      mutation: "KRAS G12S"
      cells: 6898
    - name: "NCI-H596 (HTB178)"
      mutation: "MET Del14"
      cells: 2965
    - name: "NCI-H1395 (CRL5868)"
      mutation: "BRAF G469A"
      cells: 2673
    - name: "DV90"
      mutation: "ERBB2 V842I"
      cells: 2998
    - name: "HCC78"
      mutation: "SLC34A2-ROS1 fusion"
      cells: 2748
    - name: "CCL.185-IG"
      mutation: "EML4-ALK fusion"
      cells: 6354
    - name: "PBMC"
      description: "Peripheral blood mononuclear cells from healthy donor"
      cells: 500

# Processing information (unchanged)
processing:
  software: "Cell Ranger v7.1.0"
  reference_genome: "GRCh38-2020-A"
  quantification: "intron-mode included"
  total_reads: "2.46 billion"
  q30_threshold: "≥71.26%"

# Tools and resources (unchanged)
tools:
  - name: "R Shiny Mixing App"
    url: "http://aisc.hpc4ai.unito.it:3838/"
    description: "Generate controlled mixtures of cell lines at user-defined ratios"
  - name: "Docker Container"
    url: "docker.io/repbioinfo/cellranger.2023.7.1.0"
    description: "Cell Ranger v7.1.0 for reproducing count matrix generation"

# Schema information (unchanged)
schema:
  name: "Single Cell Schema"
  version: "0.4"
  standard: "Darwin Core extension for single-cell RNA-seq"
  url: "https://singlecellschemas.org"

# Notes for users (unchanged)
notes: |
  This FAIR metadata implementation accompanies the original BE1 benchmark dataset.
  Please cite both:
  1. The original dataset publication (Arigoni et al., 2024)
  2. This metadata implementation (ELIXIR Single Cell Omics Community, 2024)
  
  The dataset contains 29,528 single-cell transcriptomes from seven lung cancer cell lines
  with distinct driver mutations, providing controlled heterogeneity for benchmarking
  computational methods. The dataset is available through:
  - GEO: GSE243665 (count matrices and configuration)
  - SRA: SRP462078 / PRJNA1019356 (raw FASTQ)
  - figshare: 10.6084/m9.figshare.23939481.v1 (count matrices in 10X format)
  - figshare: 10.6084/m9.figshare.23284748.v1 (supporting CCLE data and driver gene targets)
  
  An R Shiny App (http://aisc.hpc4ai.unito.it:3838/) enables generation of custom
  mixtures of cell lines at user-defined ratios for creating benchmark datasets with
  controlled heterogeneity levels.
  
  Key features:
  - Seven driver mutations with partially overlapping pathways
  - Isogenic pair (A549 and CCL.185-IG ALK fusion) for subtle variation detection
  - PBMC control for normal cell comparison
  - Complete Cell Ranger v7.1.0 processing with intron-mode quantification
  - Validation against CCLE bulk transcriptomes
  - BE1-500 validation dataset (500 cells per line)
