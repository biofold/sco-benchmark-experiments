{
  "study": [
    {
      "Study ID": "GSE243665",
      "Title": "A single cell RNAseq benchmark experiment embedding 'controlled' cancer heterogeneity",
      "Description": "This dataset provides single-cell transcriptomic profiles of seven lung cancer cell lines characterized by the expression of seven different driver genes (EGFR, ALK, MET, ERBB2, KRAS, BRAF, ROS1), leading to partially overlapping functional pathways. Additionally, PBMC from a healthy donor were also sequenced. The BE1 dataset serves as a controlled heterogeneous environment for the development and validation of methodologies for analysing cancer heterogeneity by means of scRNA-seq. BE1 includes scRNAseq for lung cancer cell lines with known driver mutations: PC9 (EGFR Del19, 4492 cells), A549 (KRAS p.G12S, 6898 cells), NCI-H596 (HTB178, MET Del14, 2965 cells), NCI-H1395 (CRL5868, BRAF p.G469A, 2673 cells), DV90 (ERBB2 p.V842I, 2998 cells), HCC78 (SLC34A2-ROS1 Fusion, 2748 cells), CCL.185.IG (EML4-ALK Fusion in A549 isogenic background, 6354 cells), and PBMCs from healthy donor. Total of 29,528 cells sequenced. Public release date: December 2, 2023.",
      "Bibliographic Citation": "Arigoni M, Ratto ML, Riccardo F, Balmas E et al. A single cell RNAseq benchmark experiment embedding 'controlled' cancer heterogeneity. Sci Data 2024 Feb 2;11(1):159. PMID: 38307867; doi: 10.1038/s41597-024-03002-8",
      "Created": "2023-12-02",
      "Workflow (optional)": "10X Genomics Chromium Next GEM Single Cell 3' Kit v3.1 with Cell Multiplexing (CellPlex)",
      "Technology": "10X Genomics",
      "Licence (optional)": "CC BY 4.0"
    }
  ],
  
